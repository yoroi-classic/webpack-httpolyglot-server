{
  "name": "webpack-httpolyglot-server",
  "version": "0.3.0",
  "private": true,
  "description": "Using httpolyglot to serve http/https over the same port for Webpack development server",
  "main": "lib/server.js",
  "files": [
    "lib",
    "ssl"
  ],
  "engines": {
    "node": ">=22.13.0 <23",
    "npm": ">=10"
  },
  "packageManager": "npm@10.9.7",
  "scripts": {
    "check:metadata": "node scripts/check-package-metadata.js",
    "lint": "eslint lib test scripts",
    "test": "node --test test/*.test.js",
    "verify": "npm run check:metadata && npm run lint && npm test"
  },
  "peerDependencies": {
    "webpack": "^5.0.0"
  },
  "dependencies": {
    "express": "^4.22.2",
    "httpolyglot": "^0.1.2",
    "lodash.omit": "^4.18.0",
    "webpack-dev-middleware": "^8.0.3",
    "webpack-hot-middleware": "^2.26.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "eslint": "^10.6.0",
    "globals": "^17.7.0",
    "webpack": "^5.108.4"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yoroi-classic/webpack-httpolyglot-server.git"
  },
  "bugs": {
    "url": "https://github.com/yoroi-classic/webpack-httpolyglot-server/issues"
  },
  "homepage": "https://github.com/yoroi-classic/webpack-httpolyglot-server#readme",
  "author": "Jhen <developer@jhen.me>",
  "license": "MIT"
}
